PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
OPERATOR_NAME=Operator
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

MONGO_URI=mongodb://localhost:27017/
DB_NAME=LLMmemory

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=llava
OLLAMA_TIMEOUT=120000
OLLAMA_MAX_RETRIES=3
OLLAMA_RETRY_DELAY=2000

EMBEDDING_MODEL=nomic-embed-text
VECTORSTORE_PATH=./vectorstore
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=6
RAG_MIN_SCORE=0
RAG_MAX_SCORE=1
RAG_MIN_LEXICAL_SCORE=0.1

# External APIs
NEWS_API_KEY=
NEWS_API_BASE_URL=https://newsapi.org/v2
GNEWS_API_KEY=
GNEWS_API_BASE_URL=https://gnews.io/api/v4
TMDB_API_KEY=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_REGION=US

JWT_SECRET=replace-with-32-char-minimum-secret-value
JWT_REFRESH_SECRET=replace-with-32-char-minimum-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENABLE_TTS=true
TTS_ENGINE=edge
TTS_ACCENT=auto
TTS_FILE_TTL_MS=300000

SANDBOX_ENABLED=true
SANDBOX_DOCKER_IMAGE=node:20-alpine
SANDBOX_TIMEOUT_MS=5000
SANDBOX_MEMORY_LIMIT=128m
SANDBOX_CPU_LIMIT=0.50
SANDBOX_PIDS_LIMIT=64
SANDBOX_SECCOMP_PROFILE=default
